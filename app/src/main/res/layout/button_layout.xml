<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:orientation="vertical">
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Cancel" android:onClick="dismissListener"/>
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Repeat" android:onClick="dismissListener"/>
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Skip" android:onClick="dismissListener"/>
    <Button android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Skip all" android:onClick="dismissListener"/>
</LinearLayout>